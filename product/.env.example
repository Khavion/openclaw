# SubAudit environment. Copy to product/.env and fill in. NEVER commit .env.

# --- Core ---
# Postgres connection string (local dev default shown in README-OPERATIONS.md)
DATABASE_URL=
# 64 hex chars (32 bytes). Encrypts customer credentials at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KHAVION_MASTER_KEY=
# Port for the local web app
PORT=3000
# mock = adapters read fixtures (offline dev/test). real = live APIs.
APP_MODE=mock

# --- Monitoring ---
# healthchecks.io ping URL. Nightly audit job and the Mac hourly heartbeat use it.
HEALTHCHECKS_PING_URL=

# --- GoHighLevel marketplace app (Stage 0 verify script + production) ---
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# Must exactly match the redirect URL configured on the marketplace app
GHL_REDIRECT_URI=http://localhost:3000/oauth/callback
